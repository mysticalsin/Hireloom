{
  "name": "hireloom",
  "version": "1.8.0",
  "description": "Hireloom — Your AI-Powered Career Accelerator. Scores, weaves, and queues senior-level job offers quietly and deliberately, never spammy.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dashboard-web/server.mjs",
  "bin": {
    "hireloom": "dashboard-web/server.mjs",
    "career-ops": "dashboard-web/server.mjs"
  },
  "scripts": {
    "start": "node dashboard-web/server.mjs",
    "dev": "node --watch dashboard-web/server.mjs",
    "preview": "PORT=4749 HOST=127.0.0.1 CONFIG_DIR=./tmp/preview-config DATA_DIR=./tmp/preview-data node dashboard-web/server.mjs",
    "doctor": "node doctor.mjs",
    "doctor:env": "bash install.sh --doctor",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "scan": "node scan.mjs",
    "liveness": "node check-liveness.mjs",
    "patterns": "node analyze-patterns.mjs",
    "followup": "node followup-cadence.mjs",
    "eval:gemini": "node gemini-eval.mjs",
    "latex": "node generate-latex.mjs",
    "test": "node --test \"tests/**/*.test.mjs\"",
    "test:watch": "node --test --watch \"tests/**/*.test.mjs\""
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "anthropic",
    "career",
    "career-atelier",
    "hireloom",
    "resume",
    "cv",
    "applicant-tracking",
    "automation"
  ],
  "author": "Santiago Fernández de Valderrama <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santifer/career-ops.git"
  },
  "bugs": {
    "url": "https://github.com/santifer/career-ops/issues"
  },
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.2.0",
    "playwright": "^1.58.1"
  }
}
